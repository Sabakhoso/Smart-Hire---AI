# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# SQLite Database
DATABASE_URL=sqlite:///./resume_analyzer.db

# JWT Secret Key
SECRET_KEY=your_secret_key_here

# JWT Algorithm
ALGORITHM=HS256

# JWT Expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Resume Upload Directory
UPLOAD_DIR=uploads